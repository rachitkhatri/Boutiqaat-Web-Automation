# ============================================================
# .env.example - Environment variables template
# Copy this to .env and update with your actual values
# ============================================================

# Base Configuration
BASE_URL=https://www.boutiqaat.com
ENVIRONMENT=Production

# Timeouts (milliseconds)
DEFAULT_TIMEOUT=30000
PAGE_SETTLE_MS=2000
PAYMENT_TIMEOUT=60000

# Browser Configuration
HEADLESS=false
BROWSER=chromium
SLOW_MO=0

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Reporting
REPORT_DIR=reports
SCREENSHOT_DIR=screenshots
VIDEO_DIR=videos

# API Configuration (if needed)
API_BASE_URL=https://api.boutiqaat.com
API_TIMEOUT=30

# Optional: CI/CD flags
CI=false
GENERATE_VIDEO=true
GENERATE_SCREENSHOT=true